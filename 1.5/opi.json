  "components": {

    "schemas": {

      "DownloadByKeyRequestDto": {

        "required": [

          "key"

        ],

        "type": "object",

        "properties": {

          "key": {

            "type": "string",

            "description": "Полный ключ файла в рабочем пространстве"

          },

          "workspace": {

            "type": "string",

            "description": "Рабочее пространство. По умолчанию = general"

          }

        },

        "description": "Запрос на выгрузку файла по полному ключу из рабочего пространства"

      },

      "FileResponseDto": {

        "required": [

          "fileId"

        ],

        "type": "object",

        "properties": {

          "fileId": {

            "type": "string",

            "description": "Идентификатор файла"

          },

          "workspace": {

            "type": "string",

            "description": "Рабочее пространство"

          }

        },

        "description": "Информация о файле"

      },

      "FileRgsDownloadResponse": {

        "required": [

          "fileId",

          "flkReport",

          "requestId"

        ],

        "type": "object",

        "properties": {

          "fileId": {

            "type": "string",

            "description": "Идентификатор файла в сервисе файлового хранилища",

            "format": "uuid"

          },

          "requestId": {

            "type": "string",

            "description": "Сквозной идентификатор запроса",

            "format": "uuid",

            "example": "0b5f3ab9-7891-4889-acdd-7eb91fe00551"

          },

          "flkReport": {

            "$ref": "#/components/schemas/FlkReport"

          }

        }

      },

      "FlkReport": {

        "type": "object",

        "properties": {

          "requestId": {

            "type": "string",

            "description": "Сквозной идентификатор запроса",

            "format": "uuid"

          },

          "businessObjectId": {

            "type": "string",

            "description": "Идентификатор записи договора/дополнительного соглашения",

            "format": "uuid"

          },

          "mismatches": {

            "type": "array",

            "description": "Тело отчета",

            "items": {

              "$ref": "#/components/schemas/Mismatch"

            }

          }

        },

